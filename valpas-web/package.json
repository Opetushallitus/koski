{
  "name": "valpas",
  "version": "0.0.2",
  "description": "Valpas",
  "license": "EUPL-1.1",
  "engines": {
    "node": ">=24",
    "npm": "9||10",
    "pnpm": ">=10.28.2"
  },
  "scripts": {
    "start": "node autoclear.js && PUBLIC_URL=/valpas node watch.mjs",
    "start:watch": "concurrently npm:start npm:lint:types:watch",
    "start:raamit": "node autoclear.js --dev-raamit && VIRKAILIJA_RAAMIT_HOST=true OPPIJA_RAAMIT_HOST=true PUBLIC_URL=/valpas node watch.mjs",
    "start:integration": "node autoclear.js --integration && PUBLIC_URL=/valpas node watch.mjs",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "node autoclear.js --unittest && jest --runInBand src",
    "test:integration": "pnpm run build:local && jest --config jest.integrationtests.config.js --runInBand test/integrationtests",
    "test:integration:debug": "pnpm run build:local && SHOW_BROWSER=true jest --config jest.integrationtests.config.js --runInBand test/integrationtests",
    "build:local": "node autoclear.js && PUBLIC_URL=/valpas parcel build src/index.html --public-url /valpas/assets --dist-dir dist-nonce --no-scope-hoist && node postbuild-exec.mjs",
    "build:prod": "node autoclear.js --prod && PUBLIC_URL=/valpas parcel build src/index.html --public-url /valpas/assets --dist-dir dist-nonce --no-scope-hoist && node postbuild-exec.mjs",
    "lint": "pnpm run lint:types && pnpm run lint:problems",
    "lint:types": "tsc --noEmit",
    "lint:types:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "lint:problems": "eslint \"{src,test}/**/*.{js,jsx,ts,tsx}\"",
    "fix": "pnpm run fix:format",
    "fix:format": "eslint \"{src,test}/**/*.{js,jsx,ts,tsx}\" --fix",
    "clean": "jest --clearCache && rm -rf dist && rm -rf dist-nonce && rm -rf ../target/webapp/koski/valpas && rm -rf .parcel-cache",
    "preinstall": "node -e \"if(!process.env.npm_execpath.includes(\\\"pnpm\\\")){console.error(\\\"❌ Please use pnpm\\\");process.exit(1)}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Opetushallitus/koski.git"
  },
  "homepage": "https://github.com/Opetushallitus/koski#readme",
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^29.7.0",
    "@parcel/babel-plugin-transform-runtime": "~2.16.0",
    "@parcel/config-default": "~2.16.0",
    "@parcel/core": "~2.16.0",
    "@parcel/package-manager": "~2.16.0",
    "@parcel/transformer-less": "~2.16.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/downloadjs": "^1.4.6",
    "@types/jest": "^29.5.14",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.19.15",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-test-renderer": "^19.1.0",
    "@types/selenium-webdriver": "^4.35.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "babel-jest": "^29.7.0",
    "cheerio": "^1.2.0",
    "chromedriver": "^139.0.3",
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "express": "^4.22.1",
    "http-proxy-middleware": "^3.0.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-expect-message": "^1.1.3",
    "jest-fail-on-console": "^3.3.4",
    "jest-fetch-mock": "^3.0.3",
    "js-cookie": "^3.0.5",
    "less": "^4.6.4",
    "node-fetch": "^3.3.2",
    "parcel": "~2.16.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "process": "^0.11.10",
    "selenium-webdriver": "^4.41.0",
    "tree-kill": "^1.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bem-ts": "^0.15.0",
    "copy-to-clipboard": "^3.3.3",
    "date-fns": "^4.1.0",
    "downloadjs": "^1.4.7",
    "fp-ts": "^2.16.11",
    "react": "^19.2.3",
    "react-calendar": "^6.0.0",
    "react-date-picker": "^12.0.1",
    "react-dom": "^19.2.3",
    "react-router-dom": "^5.3.4",
    "regenerator-runtime": "^0.14.1"
  },
  "alias": {
    "memoize": "./node_modules/.pnpm/memoize@10.2.0/node_modules/memoize/distribution/index.js"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.12.0",
      "brace-expansion@^1": "1.1.12",
      "brace-expansion@^2": "5.0.5",
      "js-yaml@^3": "3.14.2",
      "js-yaml@^4": "4.1.1",
      "@eslint/plugin-kit": "^0.6.0",
      "flatted": "^3.4.2"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
